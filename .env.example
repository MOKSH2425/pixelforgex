# ─────────────────────────────────────────────
#  PIXELFORGEX.DEV — Environment Variables
#  Copy this to .env.local and fill in values
# ─────────────────────────────────────────────

# Resend — https://resend.com (free tier: 3000 emails/month)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives contact form submissions
# Must be a verified domain on Resend (or use onboarding@resend.dev for testing)
CONTACT_TO_EMAIL=hello@pixelforgex.dev

# The "from" address shown in received emails
CONTACT_FROM_EMAIL=PIXELFORGEX.DEV <noreply@pixelforgex.dev>

# Site URL — used for OG images and canonical links
NEXT_PUBLIC_SITE_URL=https://pixelforgex.dev
